{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (GPU)",
      "options": {
        "baseURL": "http://192.168.2.4:1234/v1",
      }
    }
  },
  "mcp": {
    "backlog": {
      "type": "local",
      "command": ["backlog", "mcp", "start"]
    },
    "dependencies": {
      "type": "local",
      "command": ["bunx", "dependency-mcp"]
    }
  }
}
