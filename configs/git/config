[init]
	defaultBranch = main
[alias]
	st = status
	co = checkout
	br = branch
	ci = commit -S
	am = amend
	fpush = push --force-with-lease
	spush = push --signed
	fspush = push --force-with-lease --signed
[rerere]
	enabled = true
[branch]
	sort = -commiterdate
[rebase]
	updateRefs = true
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only --features=interactive
[column]
	ui = auto
[gpg]
	format = ssh
[delta]
	navigate = true
	line-numbers = true
	hyperlinks = true
	features = decorations
	hyperlinks-file-link-format = vscode://file/{path}:{line}
	file-style = bold yellow ul
	file-decoration-style = yellow ol ul
	hunk-header-decoration-style = blue
	hunk-header-line-number-style = purple bold
[user]
	signingkey = /home/me/.ssh/id_ed25519.pub
	name = S
	email = q
