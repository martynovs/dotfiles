{
  "cleanupPeriodDays": 10,
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "MAX_THINKING_TOKENS": "10000",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "permissions": {
    "allow": [
      "Skill(find-docs)",
      "Skill(pastel)",
      "Skill(cmux)",
      "Bash(cmux *)",
      "Bash(wt *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(just *)",
      "Bash(cargo *)",
      "Bash(glab issue *)",
      "Bash(glab api *)",
      "Bash(glab mr *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git status *)",
      "Bash(git reflog *)",
      "Bash(git rebase *)",
      "Bash(git commit *)",
      "Read(~/.claude/CLAUDE.md)",
      "Read(~/.claude/skills/**)",
      "Read(~/.claude/plugins/cache/**)",
      "Write(~/.docker/buildx/activity/**)",
      "mcp__pencil"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Read(~/.kube/**)",
      "Edit(~/.kube/**)",
      "Read(~/.config/**)",
      "Edit(~/.config/**)",
      "Read(~/Library/**)",
      "Edit(~/Library/**)",
      "Read(.env*)",
      "Edit(.env*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(wget *|*bash*)",
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git reset --hard*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh stop"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh stop"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh task_completed"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh notification"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh permission"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "caveman@caveman": false,
    "agent-browser@agent-browser": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "serena@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "hookify@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "mempalace@mempalace": true,
    "compound-engineering@compound-engineering-plugin": true
  },
  "extraKnownMarketplaces": {
    "agent-browser": {
      "source": {
        "source": "github",
        "repo": "vercel-labs/agent-browser"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "mempalace": {
      "source": {
        "source": "github",
        "repo": "MemPalace/mempalace"
      }
    },
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowUnixSockets": [
        "~/.docker/run/docker.sock"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.cargo/target",
        "~/.docker/buildx/activity"
      ],
      "allowRead": [
        "~/.config/git"
      ]
    },
    "excludedCommands": [
      "cmux *",
      "docker logs *",
      "terminal-notifier *"
    ]
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "medium",
  "plansDirectory": "./docs/plans",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "voiceEnabled": false,
  "showTurnDuration": true,
  "terminalProgressBarEnabled": false,
  "model": "sonnet"
}
