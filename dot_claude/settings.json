{
  "cleanupPeriodDays": 10,
  "effortLevel": "medium",
  "plansDirectory": "./docs/plans",
  "env": {
    "MAX_THINKING_TOKENS": "50000",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "cmux *"
    ]
  },
  "permissions": {
    "allow": [
      "Skill(pastel)",
      "Skill(cmux)",
      "Bash(cmux *)",
      "Bash(wt *)",
      "Bash(just test)",
      "Read(~/.claude/CLAUDE.md)",
      "Read(~/.claude/skills/**)",
      "Read(~/.claude/plugins/cache/**)",
      "mcp__plugin_context7*",
      "mcp__pencil"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Read(~/.kube/**)",
      "Edit(~/.kube/**)",
      "Read(~/.config/**)",
      "Edit(~/.config/**)",
      "Read(~/Library/**)",
      "Edit(~/Library/**)",
      "Read(.env*)",
      "Edit(.env*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(wget *|*bash*)",
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git reset --hard*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "worktrunk@worktrunk": true,
    "context7@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": false,
    "serena@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "hookify@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "superpowers@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": false
  },
  "spinnerTipsEnabled": false,
  "voiceEnabled": false,
  "showTurnDuration": true,
  "terminalProgressBarEnabled": false
}
