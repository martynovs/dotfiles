{
  "cleanupPeriodDays": 10,
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "MAX_THINKING_TOKENS": "10000",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "permissions": {
    "allow": [
      "Skill(find-docs)",
      "Skill(pastel)",
      "Skill(cmux)",
      "Bash(cmux *)",
      "Bash(wt *)",
      "Bash(git:*)",
      "Bash(just test)",
      "Bash(cargo build*)",
      "Bash(cargo check*)",
      "Bash(cargo test*)",
      "Bash(cargo clippy*)",
      "Bash(glab issue *)",
      "Bash(glab mr *)",
      "Read(~/.claude/CLAUDE.md)",
      "Read(~/.claude/skills/**)",
      "Read(~/.claude/plugins/cache/**)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Read(~/.kube/**)",
      "Edit(~/.kube/**)",
      "Read(~/.config/**)",
      "Edit(~/.config/**)",
      "Read(~/Library/**)",
      "Edit(~/Library/**)",
      "Read(.env*)",
      "Edit(.env*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(dd *)",
      "Bash(wget *|*bash*)",
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git reset --hard*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh stop"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh stop"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh task_completed"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh notification"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh permission"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "worktrunk@worktrunk": true,
    "claude-code-setup@claude-plugins-official": false,
    "serena@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "hookify@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": false,
    "agent-browser@agent-browser": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "agent-browser": {
      "source": {
        "source": "github",
        "repo": "vercel-labs/agent-browser"
      }
    },
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowUnixSockets": [
        "~/.docker/run/docker.sock"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.cargo/target"
      ]
    },
    "excludedCommands": [
      "cmux *",
      "docker logs *",
      "terminal-notifier *"
    ]
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "medium",
  "plansDirectory": "./docs/plans",
  "voiceEnabled": false,
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "showTurnDuration": true,
  "terminalProgressBarEnabled": false
}
