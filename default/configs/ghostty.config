# fonts
font-size = 24
font-family = "JetBrains Nerd Font"


# window
window-width = 999999
window-height = 999999
window-save-state = always
macos-titlebar-style = tabs

# transparent..opaque = 0..1
background-opacity = 0.2
# reasonable blur values 0..20 or true/false
background-blur = 10


# quick terminal
quick-terminal-position = bottom
quick-terminal-animation-duration = 0
keybind = global:super+§=toggle_quick_terminal

# keys
